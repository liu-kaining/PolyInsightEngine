# Backend
PORT=8080
REDIS_URL=redis://127.0.0.1:6379
CLICKHOUSE_URL=http://127.0.0.1:8123
GAMMA_API_BASE=https://gamma-api.polymarket.com

# Polymarket CLOB — order book midpoint / last-trade prices for YES token implied probability.
# 盘口真实价格：K 线入库与 oracle 套利循环均从此端点拉取 CLOB 行情。
CLOB_API_BASE=https://clob.polymarket.com

# Polymarket Subgraph — on-chain trade feed for the Smart Money / whale tracker (backend polls GraphQL).
# 链上大单数据源：后端从此 Subgraph 拉取交易；生产环境请换成 Goldsky 或自建稳定端点。
POLYMARKET_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/polymarket/polymarket

